{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "firestore.rules", "SETUP.md", "node_modules", ".git"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
